# ─── Django ─────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this
DEBUG=False

# ─── PostgreSQL Database ────────────────────────────────────
# Railway sets DATABASE_URL automatically — do NOT add it manually on Railway.
# For LOCAL development, set it here:
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/feel_comfort_db

# ─── LLM ────────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ─── Optional: Ollama (local only) ──────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
